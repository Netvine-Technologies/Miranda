APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
CORS_ALLOWED_ORIGINS=http://localhost:3000
GOOGLE_PLACES_ENDPOINT=https://places.googleapis.com/v1
GOOGLE_PLACES_REGION_CODE=GB
LEAD_SCAN_DEPTH_DEFAULT=standard
GOOGLE_PLACES_TEXT_SEARCH_PRO_PER_1000=32
GOOGLE_PLACES_PLACE_DETAILS_PRO_PER_1000=17
GOOGLE_PLACES_FREE_CALLS_PER_SKU_PER_MONTH=5000
LEAD_EMAIL_DOMAIN_FILTER_ENABLED=true
LEAD_EMAIL_ALLOW_EXTERNAL_DOMAINS=
LEAD_EMAIL_DENY_DOMAINS=sentry.io,sentry.wixpress.com

SHOPIFY_HTTP_VERIFY_SSL=true
FRONTEND_COMPARE_URL_TEMPLATE=

INTERNAL_API_REQUIRE_SIGNATURE=true
INTERNAL_API_SECRET=
INTERNAL_API_CLIENT_ID=node-app
INTERNAL_API_ALLOWED_IPS=
INTERNAL_API_MAX_SKEW_SECONDS=300
INTERNAL_API_REQUEST_ID_TTL_SECONDS=300

PRICE_WATCH_ALERT_MODE=any_change
PRICE_WATCH_COOLDOWN_MINUTES=0
